{
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.07,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 10000,
    "cancel_open_orders_on_exit": false,
    "margin_mode": "isolated",
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "bybit",
        "key": "VOTRE_CLE_BYBIT",
        "secret": "VOTRE_SECRET_BYBIT",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT",
            "BNB/USDT:USDT",
            "ADA/USDT:USDT",
            "XRP/USDT:USDT",
            "LINK/USDT:USDT",
            "AVAX/USDT:USDT"
        ],
        "pair_blacklist": [
            "DOGE/USDT"
        ]
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret": "my-secret-key",
        "ws_token": "my-ws-token",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "superpassword"
    },
    "bot_name": "freqtrade_bot",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "trading_mode": "futures",
    "freqai": {
        "enabled": true,
        "purge_old_models": true,
        "train_period_days": 180,
        "backtest_period_days": 7,
        "identifier": "bybit-futures-predator-v8-1",
        "model_training_parameters": {
            "n_estimators": 1000,
            "learning_rate": 0.05,
            "max_depth": 6,
            "num_leaves": 36,
            "verbose": -1,
            "random_state": 42
        },
        "feature_parameters": {
            "include_timeframes": [
                "15m",
                "1h"
            ],
            "include_corr_pairlist": [
                "BTC/USDT:USDT",
                "ETH/USDT:USDT",
                "SOL/USDT:USDT",
                "BNB/USDT:USDT"
            ],
            "label_period_candles": 24,
            "include_shifted_candles": 2,
            "principal_component_analysis": true,
            "use_SVM_to_remove_outliers": false,
            "svm_params": {
                "nu": 0.05,
                "shuffle": false
            },
            "indicator_periods_candles": [
                10,
                48,
                96
            ]
        },
        "data_split_parameters": {
            "test_size": 0.25,
            "shuffle": false
        }
    }
}